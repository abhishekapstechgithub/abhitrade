# ── Dependencies & build artifacts ───────────────────────────────────────────
node_modules
.next
out

# ── Git ───────────────────────────────────────────────────────────────────────
.git
.gitignore
.gitattributes

# ── Environment files (injected at runtime via docker-compose env:) ───────────
.env
.env.local
.env.*.local

# ── Large data files and non-web directories ─────────────────────────────────
*.csv
*.txt
*.zip
tmp/
mobile_app/
.claude/
tsconfig.tsbuildinfo
next-env.d.ts
screenshot.mjs
CREDENTIALS.md
workers/
certbot/
nginx/

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# ── Type-check artifacts ──────────────────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ── OS / IDE ──────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode
.idea
*.swp
*.swo

# ── Docs / CI (not needed inside image) ──────────────────────────────────────
README.md
CLAUDE.md
*.md
.github/

# ── Docker files (avoid recursive context copying) ────────────────────────────
docker-compose*.yml
Dockerfile*
