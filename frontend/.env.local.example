# Backend Express API URL (used by Next.js rewrites in next.config.mjs)
# Dev: Express backend runs on :3001
# Docker: set to http://backend-api:3001 (internal network)
BACKEND_API_URL=http://localhost:3001

# Exposed to browser — points at the public API URL (via nginx in prod)
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=ws://localhost:3001
