# ─────────────────────────────────────────────────────────────────────────────
#  AbhiTrade — Environment Variables Reference
#  Copy to .env.local and fill in your values.
#
#  For Docker Compose services, these vars are resolved from the .env file
#  in the project root (same directory as docker-compose.yml).
#  For Next.js local dev (npm run dev), name the copy .env.local.
#
#  IMPORTANT: PostgreSQL and Redis must run as Docker containers.
#  Start them with:  docker compose up -d postgres redis
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# When running via Docker Compose, POSTGRES_HOST must be the service name "postgres"
# When running Next.js locally (outside Docker), use "localhost"
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=abhitrade
POSTGRES_USER=abhitrade
POSTGRES_PASSWORD=abhitrade
# Set to "true" only when connecting to a hosted PostgreSQL with TLS (e.g., Render, Supabase)
POSTGRES_SSL=false

# ── Redis ─────────────────────────────────────────────────────────────────────
# When running via Docker Compose, REDIS_HOST must be the service name "redis"
# When running locally (npm run dev without Docker), use "localhost"
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── Next.js API base URL ──────────────────────────────────────────────────────
# Exposed to the browser — use the public hostname/port in production
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# ── Auth ──────────────────────────────────────────────────────────────────────
# Change this to a long random string in production
# Generate one: openssl rand -hex 32
JWT_SECRET=abhitrade-dev-secret-change-in-production

# ── File uploads ──────────────────────────────────────────────────────────────
# Where uploaded security-master CSV/ZIP files are temporarily stored
# Docker Compose maps this to the named "uploads" volume
UPLOAD_DIR=/tmp/abhitrade-uploads
